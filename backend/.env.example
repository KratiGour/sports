# APPLICATION SETTINGS
APP_NAME="Cricket Highlight Generator"
APP_VERSION="1.0.0"
ENVIRONMENT="development"  # development, staging, production
DEBUG=True
LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# API SERVER
API_HOST="0.0.0.0"
API_PORT=8000
API_RELOAD=True
JWT_SECRET_KEY="your_jwt_secret"
JWT_ALGORITHM="HS256"
JWT_EXPIRATION_MINUTES=10080  # 7 days

# DATABASE CONFIGURATION
# Choose ONE database option based on deployment environment

# DEVELOPMENT: Local PostgreSQL
# DATABASE_TYPE="postgresql"
# DATABASE_URL="postgresql://postgres:password@localhost:5432/sports_dev"
# POSTGRES_PASSWORD="password"
# POSTGRES_DB="sports_dev"
# POSTGRES_PORT=5432

# PRODUCTION: Cloud SQL (Google Cloud)
# DATABASE_TYPE="postgresql"
# DATABASE_URL="postgresql://postgres:PASSWORD@10.0.0.3:5432/sports"
# POSTGRES_PASSWORD="PASSWORD"
# POSTGRES_DB="sports"
# POSTGRES_PORT=5432
 
# GOOGLE GENERATIVE AI (GEMINI)
# Get API key from: https://ai.google.dev/
# Add multiple keys for fallback/rotation (optional)
# GEMINI_API_KEY_1="your_api_key_1_here"
# GEMINI_API_KEY_2="your_api_key_2_here"
# GEMINI_API_KEY_3="your_api_key_3_here"

# Model selection
GEMINI_MODEL="gemini-2.5-flash"  # gemini-pro, gemini-pro-vision, gemini-2.5-flash

# VIDEO PROCESSING SETTINGS(loallly)
# Video Storage Paths
VIDEO_STORAGE_RAW="storage/raw"  # Downloaded videos
VIDEO_STORAGE_TRIMMED="storage/trimmed"  # Individual clips
VIDEO_STORAGE_FINAL="storage/final"  # Final supercut videos

# Video Processing
VIDEO_QUALITY="best"  # best, 1080p, 720p, 480p
VIDEO_FORMAT="mp4"
VIDEO_CODEC="copy"  # copy = fast (no re-encoding), h264 = re-encode

# Event Clip Settings (in seconds)
CLIP_BUFFER_WICKET=15  # ±15 seconds for wickets
CLIP_BUFFER_BOUNDARY=10  # ±10 seconds for fours/sixes
CLIP_MERGE_THRESHOLD=10  # Merge clips if within 10 seconds

# FFmpeg Settings
FFMPEG_THREADS=4  # CPU threads for processing
FFMPEG_PRESET="fast"  # ultrafast, fast, medium, slow

# YOUTUBE DOWNLOAD SETTINGS
YOUTUBE_DOWNLOAD_ENABLED=True
YOUTUBE_MAX_FILE_SIZE_GB=15  # Maximum video size to download
YOUTUBE_TIMEOUT_SECONDS=300  # 5 minutes

# CACHE & PERFORMANCE
REDIS_ENABLED=False
REDIS_URL="redis://localhost:6379/0"
CACHE_TTL=3600  

# TASK QUEUE (Celery)
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"
CELERY_ENABLED=False

# MONITORING & LOGGING
LOG_FILE_PATH="logs/cricket_highlights.log"
LOG_ROTATION="10 MB"
LOG_RETENTION="30 days"

# RATE LIMITING
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=3600

# CORS
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"
CORS_CREDENTIALS=True
CORS_METHODS="GET,POST,PUT,DELETE,OPTIONS"
CORS_HEADERS="*"

# FEATURE FLAGS
FEATURE_USER_UPLOADS=True  # Allow users to upload videos
FEATURE_YOUTUBE_DOWNLOAD=True  # Allow YouTube downloads
FEATURE_BATCH_PROCESSING=True  # Process multiple videos at once
FEATURE_AUTO_CLEANUP=True  # Auto-delete old files
CLEANUP_AFTER_DAYS=7  # Delete videos older than 7 days

# Deployment info
GCP_PROJECT="sports-ai-489110"  # Your GCP project ID
GCP_LOCATION="asia-south1"  # GCP region (asia-south1, us-central1, europe-west1)
GCP_REGION="asia-south1"

# Frontend/CORS configuration
FRONTEND_URL="https://sports-teal-two.vercel.app"
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000,https://sports-teal-two.vercel.app"

# Cloud Tasks -- async job processing queue
GCP_TASK_QUEUE="video-processing"
GCP_TASK_QUEUE_BATTING="batting-analysis"
GCP_TASK_QUEUE_BOWLING="bowling-analysis"
WORKER_SERVICE_URL="https://video-worker-abcde.run.app"  # Cloud Run URL for task worker
WORKER_SERVICE_ACCOUNT_EMAIL="example@project-id.iam.gserviceaccount.com"

# Google Application Credentials
# For local development only - Cloud Run uses Workload Identity
# Download from GCP Console → Service Accounts → Create/Download JSON key
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account-key.json"

# Worker authentication (optional - for securing task queue webhooks)
# Leave empty to rely on Cloud Run IAM authentication
# WORKER_AUTH_SECRET=""
