#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "Starting pre-commit checks..."

# Check Frontend Types (Navigate to subdir for tsconfig.json)
echo "Checking TypeScript types in frontend..."
cd frontend
npx tsc --noEmit
cd ..

# Run lint-staged
echo "Running lint-staged..."
npx lint-staged

echo "Pre-commit checks passed!"